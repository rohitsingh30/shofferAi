# Database
DATABASE_URL=postgresql://shofferai:shofferai_dev@localhost:5432/shofferai

# Auth (generate with: npx auth secret)
AUTH_SECRET=
AUTH_URL=https://shofferai-27188185100.asia-south1.run.app
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Azure OpenAI (GPT-5.1 via Azure)
LLM_MODEL=gpt-5.1-chat                     # Azure deployment name
AZURE_OPENAI_ENDPOINT=                      # e.g. https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
REWRITER_MODEL=                             # Optional: fast/cheap model for message rewriting (defaults to LLM_MODEL)

# Credential Encryption Key (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
CREDENTIAL_ENCRYPTION_KEY=

# Playwright MCP (operator's signed-in Chrome profile on laptop)
PLAYWRIGHT_HEADLESS=false
CHROME_CDP_ENDPOINT=http://localhost:9222
CHROME_USER_DATA_DIR=/Users/rohit/Library/Application Support/Google/Chrome-Debug
CHROME_PROFILE_DIRECTORY=Profile 3             # rsinghtomar3011@gmail.com (Genius Level 1)

# Relay (cloud ↔ laptop)
RELAY_MODE=local                          # 'local' (dev) or 'cloud' (production — laptop connects to Cloud Run)
RELAY_LAPTOP_URL=ws://localhost:8765      # Dev only: local relay server URL
RELAY_AUTH_TOKEN=                          # Shared secret for relay auth

# Laptop → Cloud Run (production, set on operator laptop)
# RELAY_CLOUD_URL=wss://shofferai-27188185100.asia-south1.run.app/api/relay/ws

# Razorpay (Payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# App
NEXT_PUBLIC_APP_URL=https://shofferai-27188185100.asia-south1.run.app
NODE_ENV=development
LOG_LEVEL=info
